generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Regime {
  PRESUMIDO
  SIMPLES
}

enum OrigemNf {
  NOVO
  PENDENTE_ANTERIOR
}

enum StatusNf {
  PENDENTE
  INCLUIDA
}

enum UserRole {
  ADMIN
  STAFF
}

model User {
  id           String      @id @default(cuid())
  name         String
  email        String      @unique
  passwordHash String
  role         UserRole    @default(STAFF)
  createdAt    DateTime    @default(now())
  historicos   Historico[]
}

model Cliente {
  id                    String   @id @default(cuid())
  empresa               String
  profissional          String
  regime                Regime
  aliquotaSimplesMensal Decimal? @db.Decimal(6, 4)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  custosFixos   CustoFixo[]
  notasFiscais  NotaFiscal[]
  historicos    Historico[]
}

model CustoFixo {
  id        String  @id @default(cuid())
  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  desc      String
  valor     Decimal @db.Decimal(12, 2)
  ativo     Boolean @default(true)
}

model NotaFiscal {
  id          String     @id @default(cuid())
  clienteId   String
  cliente     Cliente    @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  tomador     String
  prestador   String
  numero      String
  data        String
  valorBruto  Decimal    @db.Decimal(12, 2)
  irRetPct    Decimal?   @db.Decimal(6, 4)
  issRetPct   Decimal?   @db.Decimal(6, 4)
  incluido    Boolean    @default(true)
  origem      OrigemNf   @default(NOVO)
  cancelada   Boolean    @default(false)
  status      StatusNf   @default(PENDENTE)
  historicoId String?
  historico   Historico? @relation(fields: [historicoId], references: [id])
  createdAt   DateTime   @default(now())

  @@index([clienteId, status])
}

model Historico {
  id               String       @id @default(cuid())
  clienteId        String
  cliente          Cliente      @relation(fields: [clienteId], references: [id])
  clienteNomeSnap  String
  profissionalSnap String
  regimeSnap       Regime
  dataGeracao      DateTime     @default(now())
  resultadoJson    Json
  createdByUserId  String?
  createdByUser    User?        @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  notasFiscais     NotaFiscal[]

  @@index([clienteId, dataGeracao])
}

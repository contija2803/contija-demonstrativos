# Postgres (Neon, via Vercel's Neon integration) — pooled connection for the app,
# unpooled/direct connection for migrations. Names must match what the Vercel
# Neon integration injects automatically.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true"
DATABASE_URL_UNPOOLED="postgresql://user:password@host/dbname?sslmode=require"

# Auth.js
NEXTAUTH_SECRET="generate with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# First admin user, created by `npx prisma db seed`
ADMIN_NAME="Admin"
ADMIN_EMAIL="admin@contija.com.br"
ADMIN_PASSWORD="change-me"
